YCM_APP_NAME=YouTube Upload Manager
YCM_ENVIRONMENT=development
YCM_DATABASE_URL=postgresql+psycopg2://ycm:ycm@postgres:5432/ycm
YCM_REDIS_URL=redis://redis:6379/0
YCM_VIDEO_ROOT=/srv/ycm/inbox
YCM_ARTIFACTS_ROOT=/srv/ycm/artifacts
YCM_SCHEDULER_SCAN_INTERVAL_SECONDS=300

YCM_DEFAULT_LANGUAGE=pt-BR
YCM_DEFAULT_MODEL_PROVIDER=opencloud

YCM_TELEGRAM_WEBHOOK_SECRET=change-me
YCM_API_TOKEN=

YCM_YOUTUBE_CHANNEL_ID=
YCM_YOUTUBE_CLIENT_ID=
YCM_YOUTUBE_CLIENT_SECRET=
YCM_YOUTUBE_REDIRECT_URI=http://localhost:8000/ui/youtube/oauth/callback
YCM_YOUTUBE_TOKEN_FILE=./data/youtube_token.json

YCM_STEAM_API_KEY=
YCM_STEAM_DOMAIN=localhost
YCM_STEAM_ID=
YCM_N8N_WEBHOOK_URL=

# Backward-compatible plain env keys
STEAM_API_KEY=
STEAM_DOMAIN=localhost
STEAM_ID=
N8N_WEBHOOK_URL=

# YouTube OAuth2 (set these, then set DRY_RUN=false)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
DRY_RUN=true
YCM_DRY_RUN=true

OPENCLOUD_API_KEY=

POSTGRES_DB=ycm
POSTGRES_USER=ycm
POSTGRES_PASSWORD=ycm
